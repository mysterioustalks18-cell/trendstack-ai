rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tools
    // Fields: name, tagline, description, category, pricing, trending, hidden, upcoming, rating, reviewsCount, websiteUrl, useCases, pros, cons, alternatives, videoPreviewUrl, trendingScore, growthIndicator, earlySignal, launchStage, futureImpact, verified, qualityScore, isToolOfTheDay, createdAt
    //
    // Collection: news
    // Fields: title, summary, content, imageUrl, tags, author, publishedAt, insight, type
    //
    // Collection: workflows
    // Fields: goal, steps, userId, createdAt
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, bookmarks, role, isCreator, collections
    //
    // Collection: analytics
    // Fields: toolId, views, clicks, revenue, date
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "worldstory362@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidTool(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.tagline is string && data.tagline.size() < 200 &&
             data.description is string && data.description.size() < 5000 &&
             data.category in ["Writing", "Video", "Image", "Automation", "Coding", "Marketing", "Business", "Productivity"] &&
             data.websiteUrl is string && data.websiteUrl.size() < 500;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 100 &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.role in ['user', 'admin'];
    }

    function isValidWorkflow(data) {
      return data.goal is string && data.goal.size() > 0 && data.goal.size() < 500 &&
             data.userId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Tools: Publicly readable, admin writable
    match /tools/{toolId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidTool(request.resource.data);
    }

    // News: Publicly readable, admin writable
    match /news/{newsId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Workflows: Owner readable/writable
    match /workflows/{workflowId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidWorkflow(request.resource.data);
      allow update, delete: if isOwner(resource.data.userId) && isValidWorkflow(request.resource.data);
    }

    // Users: Owner readable/writable, admin readable
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }

    // Analytics: Admin only
    match /analytics/{analyticsId} {
      allow read, write: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
